# Copy this to .env and fill in your values

APP_ENV=production
SECRET_KEY=replace-with-a-long-random-string

# SQLite (default) - no setup needed
DATABASE_URL=sqlite+aiosqlite:///./voto_peru.db

# PostgreSQL (recommended for production with many votes)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/voto_peru

# Redis (optional - improves rate limiting across multiple workers)
# REDIS_URL=redis://localhost:6379

# Frontend origins (comma-separated in env, list in code)
# Add your Vercel deployment URL here
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# reCAPTCHA v3 (get keys from console.cloud.google.com)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_ENABLED=false
