# Copy to .env.local for development
# The vite proxy handles /api locally, so this is only needed for production builds

# Production: your GCP VM domain or IP
VITE_API_URL=https://tudominio.com/api

# reCAPTCHA v3 site key (public key - safe to expose in frontend)
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=
